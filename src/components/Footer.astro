---
const currentYear = new Date().getFullYear();
---

<footer class="mt-auto w-full relative z-20 border-t border-outline/10 bg-surface/50 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-8 flex flex-col md:flex-row items-center justify-between gap-6">
    
    <div class="font-mono text-[13px] font-medium text-on-surface-variant flex items-center gap-2 bg-surface-container-lowest px-4 py-2 rounded-full shadow-sm border border-outline-variant/30">
      <span class="material-symbols-outlined text-primary text-sm">terminal</span> 
      <span>&copy; {currentYear} Ridwan. Engineered for Scalability.</span>
    </div>
    
    <div class="flex gap-6 font-mono text-[12px] uppercase tracking-widest text-secondary font-semibold">
      <a href="https://www.linkedin.com/in/ridwanafazn/" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors duration-200">
        LinkedIn
      </a>
      <a href="https://github.com/ridwanafazn" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors duration-200">
        GitHub
      </a>
      <a class="hover:text-primary transition-colors duration-200 flex items-center gap-1">
        <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
        System Status
      </a>
    </div>

  </div>
</footer>