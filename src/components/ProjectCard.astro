---
import type { Project } from '../types';
import Badge from './Badge.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}projects/${project.id}`} class="bento-card group flex flex-col p-8 min-h-[320px] relative overflow-hidden outline-none focus-visible:ring-2 focus-visible:ring-primary block">
  
  <div class="absolute -bottom-12 -right-12 w-48 h-48 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-colors duration-500 pointer-events-none z-0"></div>
  
  <div class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity duration-500 pointer-events-none dot-pattern z-0"></div>

  <div class="relative z-10 flex flex-col h-full flex-grow">
    
    <div class="flex justify-between items-start mb-6">
      <span class="font-mono text-xs font-semibold tracking-wider text-secondary bg-secondary/10 border border-secondary/20 px-3 py-1.5 rounded-full uppercase">
        {project.role}
      </span>
      
      {project.isTopProject && (
        <div class="flex items-center justify-center p-1" title="Featured Masterpiece">
          <div class="h-2 w-2 rounded-full bg-primary shadow-[0_0_8px_var(--color-primary)] animate-pulse"></div>
        </div>
      )}
    </div>

    <div class="flex-grow flex flex-col">
      <h3 class="text-2xl font-bold text-on-background mb-3 group-hover:text-primary transition-colors duration-300">
        {project.title}
      </h3>
      <p class="text-on-surface-variant text-sm leading-relaxed mb-6">
        {project.description}
      </p>
    </div>

    <div class="flex flex-wrap gap-2 mt-auto pt-5 border-t border-outline-variant/30">
      {project.techStack.map((tech) => (
        <Badge text={tech} />
      ))}
    </div>
    
  </div>
</a>