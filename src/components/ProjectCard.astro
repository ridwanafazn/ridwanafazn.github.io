---
import type { Project } from '../types';
import Badge from './Badge.astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}projects/${project.id}`} class="group relative flex flex-col bg-white rounded-2xl p-6 border border-slate-200 hover:border-teal-300 hover:shadow-sm hover:-translate-y-1 transition-all duration-200">
  <!-- Status Badge (Top Project) -->
  {project.isTopProject && (
    <div class="absolute top-6 right-6">
      <div class="h-2 w-2 rounded-full bg-teal-500 shadow-[0_0_8px_rgba(20,184,166,0.8)] animate-pulse"></div>
    </div>
  )}

  <div class="mb-4">
    <p class="text-sm font-mono text-teal-600 mb-1">{project.role}</p>
    <h3 class="text-xl font-semibold text-slate-900 group-hover:text-teal-700 transition-colors">
      {project.title}
    </h3>
  </div>
  
  <p class="text-slate-600 text-sm leading-relaxed mb-6 flex-grow">
    {project.description}
  </p>

  <div class="flex flex-wrap gap-2 mt-auto pt-4 border-t border-slate-100">
    {project.techStack.map((tech) => (
      <Badge text={tech} />
    ))}
  </div>
</a>