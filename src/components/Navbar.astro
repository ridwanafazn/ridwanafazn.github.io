---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// Helper untuk menggabungkan path dengan base secara aman
const joinPath = (path: string) => {
  const cleanBase = base.endsWith('/') ? base : `${base}/`;
  const cleanPath = path.startsWith('/') ? path.substring(1) : path;
  return `${cleanBase}${cleanPath}`;
};

// Logika deteksi halaman aktif yang robust
const isCurrent = (targetPath: string) => {
  const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
  const normalizedTarget = joinPath(targetPath).replace(/\/$/, '') || '/';
  
  if (normalizedTarget === '/') return normalizedCurrent === '/';
  return normalizedCurrent.startsWith(normalizedTarget);
};
---

<header class="fixed top-0 w-full z-50 flex justify-center mt-0 md:mt-4 pointer-events-none">
  <div class="pointer-events-auto bg-surface/80 backdrop-blur-xl border-b md:border border-outline/40 w-full md:w-auto md:rounded-full px-6 md:px-8 h-14 md:h-16 flex items-center justify-between gap-8 md:gap-16 shadow-sm transition-all duration-300 hover:shadow-md">
    
    <a href={joinPath('/')} class="flex items-center gap-2 group shrink-0">
      <span class="font-mono font-bold text-on-background group-hover:text-accent-indigo transition-colors tracking-tight text-[15px]">
        ridwanafazn
      </span>
      <span class="w-1.5 h-3.5 bg-accent-indigo animate-pulse"></span>
    </a>

    <nav class="hidden md:flex items-center gap-8 pt-1">
      <a 
        href={joinPath('/')} 
        class={`text-[13px] transition-all duration-300 pb-1.5 border-b-[2px] ${isCurrent('/') ? 'font-bold text-on-background border-on-background' : 'font-medium text-on-surface-variant border-transparent hover:text-on-background'}`}
      >
        Home
      </a>
      <a 
        href={joinPath('/about')} 
        class={`text-[13px] transition-all duration-300 pb-1.5 border-b-[2px] ${isCurrent('/about') ? 'font-bold text-on-background border-on-background' : 'font-medium text-on-surface-variant border-transparent hover:text-on-background'}`}
      >
        About
      </a>
      <a 
        href={joinPath('/projects')} 
        class={`text-[13px] transition-all duration-300 pb-1.5 border-b-[2px] ${isCurrent('/projects') ? 'font-bold text-on-background border-on-background' : 'font-medium text-on-surface-variant border-transparent hover:text-on-background'}`}
      >
        Projects
      </a>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a 
        href="https://drive.google.com/file/d/1_hsaSgJN3LB2mdCuJZWMJlVT1rH6dqqS/view" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="hidden md:inline-flex items-center justify-center border border-outline-strong text-on-surface-variant font-mono text-[11px] uppercase tracking-wider font-bold px-4 py-2 rounded-full hover:bg-surface-hover hover:text-on-background hover:border-on-background transition-all duration-300"
      >
        Resume
      </a>
      <a 
        href="mailto:ridwanafazn@gmail.com" 
        class="inline-flex items-center justify-center bg-on-background text-surface font-mono text-[11px] uppercase tracking-wider font-bold px-4 py-2 rounded-full border border-on-background hover:bg-accent-indigo hover:border-accent-indigo active:scale-95 transition-all duration-300 shadow-sm"
      >
        Hire Me
      </a>
    </div>

  </div>
</header>