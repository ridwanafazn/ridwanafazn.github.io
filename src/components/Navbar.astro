---
const base = import.meta.env.BASE_URL;
---

<header class="fixed top-0 w-full z-50 bg-[#FAFAF9]/80 backdrop-blur-md border-b border-slate-200/60">
  <div class="max-w-6xl mx-auto px-6 md:px-12 h-16 flex items-center justify-between">
    <a href={base} class="flex items-center gap-2 group">
      <span class="font-mono font-medium text-slate-900 group-hover:text-teal-700 transition-colors">
        ~/ridwan
      </span>
      <span class="w-2 h-4 bg-teal-600 animate-pulse"></span>
    </a>

    <nav class="flex items-center gap-6">
      <a href={base} class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">Home</a>
      <a href={`${base}about`} class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">About</a>
      <a href={`${base}projects`} class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">Projects</a>
    </nav>
  </div>
</header>