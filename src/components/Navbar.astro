---
const base = import.meta.env.BASE_URL;
---

<header class="fixed top-0 w-full z-50 flex justify-center mt-0 md:mt-4 pointer-events-none">
  <div class="pointer-events-auto bg-surface/80 backdrop-blur-md border-b md:border border-outline/20 w-full md:w-auto md:rounded-full px-6 md:px-8 h-16 flex items-center justify-between gap-8 md:gap-16 shadow-sm transition-all duration-300 hover:shadow-md">
    
    <a href={base} class="flex items-center gap-2 group shrink-0">
      <span class="font-mono font-semibold text-on-background group-hover:text-primary transition-colors tracking-tight">
        ridwanafazn
      </span>
      <span class="w-2 h-4 bg-primary animate-pulse"></span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href={base} class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Home</a>
      <a href={`${base}about`} class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">About</a>
      <a href={`${base}projects`} class="text-sm font-medium text-on-surface-variant hover:text-primary transition-colors">Projects</a>
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a href="https://drive.google.com/file/d/1_hsaSgJN3LB2mdCuJZWMJlVT1rH6dqqS/view" target="_blank" rel="noopener noreferrer" class="hidden md:inline-flex items-center justify-center border border-outline-variant text-tertiary font-mono text-xs px-4 py-2 rounded-full hover:bg-surface-variant hover:text-on-background transition-all duration-300">
        Resume
      </a>
      <a href="mailto:ridwan@example.com" class="inline-flex items-center justify-center bg-primary-container text-on-primary-container font-mono text-xs font-bold px-4 py-2 rounded-full border border-primary-container hover:opacity-85 active:scale-95 transition-all duration-300 shadow-sm">
        Initialize Contact
      </a>
    </div>

  </div>
</header>