---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;

// Pengamanan URL untuk aset statis (Favicon)
const base = import.meta.env.BASE_URL;
const faviconUrl = `${base.endsWith('/') ? base : base + '/'}favicon.svg`;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href={faviconUrl} />
        <meta name="generator" content={Astro.generator} />
        
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">
        
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL,GRAD,opsz@100..700,0..1,-50..200,24&display=swap" rel="stylesheet" />
        
        <title>{title} | Wang.Architect</title>
    </head>
    
    <body class="flex flex-col min-h-screen blueprint-grid relative overflow-x-hidden">
        
        <div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
            
            <div class="absolute top-[-10%] right-[-5%] w-[45rem] h-[45rem] bg-accent-indigo/10 rounded-full blur-[120px]"></div>
            <div class="absolute bottom-[-10%] left-[-10%] w-[35rem] h-[35rem] bg-accent-cyan/10 rounded-full blur-[100px]"></div>
            
            <div class="absolute top-10 -left-32 w-[40rem] h-[40rem] ornament-dashed-circle opacity-60 flex items-center justify-center">
                <div class="w-full h-[1px] bg-on-background/10 absolute"></div>
                <div class="h-full w-[1px] bg-on-background/10 absolute"></div>
            </div>
            
            <div class="absolute bottom-32 -right-16 w-80 h-80 ornament-dashed-circle opacity-80">
                <div class="absolute inset-20 border-2 border-on-background/10 rounded-full"></div>
            </div>

            <div class="absolute top-0 right-0 w-1/3 h-[500px] diagonal-pattern opacity-60" style="-webkit-mask-image: linear-gradient(to bottom left, black, transparent);"></div>
        </div>

        <Navbar />
        
        <main class="flex-grow pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto w-full relative z-10">
            <slot />
        </main>
        
        <Footer />
    </body>
</html>