---
import Layout from '../layouts/Layout.astro';
import profileData from '../data/profile.json';
import activitiesData from '../data/activities.json';
---

<Layout title="About & Impact">
  <div class="pt-10 mb-12">
    <h1 class="text-4xl font-bold text-slate-900 mb-4">The Engineer Behind the Code</h1>
    <p class="text-lg text-slate-600 max-w-2xl">
      Beyond the architecture diagrams and terminal, here is my academic foundation and how I try to make a positive impact on the community.
    </p>
  </div>

  <section class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-10">
    <!-- Education & Certifications -->
    <div>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 14l9-5-9-5-9 5 9 5z"></path><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"></path></svg>
        Education History
      </h2>
      <div class="space-y-6">
        {profileData.education.map((edu) => (
          <div class="border-l-2 border-teal-200 pl-4 relative">
            <div class="absolute w-2 h-2 bg-teal-500 rounded-full -left-[5px] top-2"></div>
            <h3 class="text-lg font-semibold text-slate-900">{edu.degree}</h3>
            <p class="text-slate-600 font-medium mb-1">{edu.institution}</p>
            <p class="text-sm font-mono text-slate-500 mb-2">GPA: {edu.gpa}</p>
            <ul class="list-disc list-inside text-sm text-slate-600 space-y-1">
              {edu.highlights.map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <h3 class="text-lg font-semibold text-slate-900 mt-10 mb-4">Professional Certifications</h3>
      <div class="space-y-3">
        {profileData.certifications.map((cert) => (
          <div class="bg-white p-4 rounded-lg border border-slate-200 shadow-sm flex justify-between items-center">
            <span class="font-medium text-slate-800">{cert.name}</span>
            <span class="text-xs font-mono px-2 py-1 bg-slate-100 text-slate-600 rounded">
              {cert.issuer}
            </span>
          </div>
        ))}
      </div>
    </div>

    <!-- Impact / Activities -->
    <div>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 flex items-center gap-2">
        <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
        Social Impact
      </h2>
      <div class="space-y-6">
        {activitiesData.map((activity) => (
          <div class="bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-semibold text-slate-900">{activity.title}</h3>
              <span class="text-xs font-mono px-2 py-1 bg-slate-100 text-slate-600 rounded">
                {activity.type}
              </span>
            </div>
            <p class="text-sm text-teal-700 font-medium mb-2">@ {activity.organization}</p>
            <p class="text-sm text-slate-600 mb-3">{activity.description}</p>
            <div class="flex flex-wrap gap-2">
              {activity.highlights.map((h) => (
                <span class="text-xs text-slate-500 before:content-['#'] before:mr-0.5">{h}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>