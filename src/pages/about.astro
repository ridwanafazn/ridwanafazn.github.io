---
import Layout from '../layouts/Layout.astro';
import profileData from '../data/profile.json';
import activitiesData from '../data/activities.json';
---

<Layout title="Background & Architecture">
  <header class="mb-20 pt-8 relative z-10">
    <h1 class="text-5xl md:text-6xl font-bold text-on-background mb-6 tracking-tight">The Engineer Behind the Code</h1>
    <p class="text-lg text-on-surface-variant max-w-2xl leading-relaxed">
      Beyond the architecture diagrams and terminal logs. This is the academic foundation, professional accreditations, and social impact that shapes my engineering mindset.
    </p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 relative z-10 mb-16">
    
    <section class="md:col-span-8 bento-card p-8 md:p-10 relative overflow-hidden">
      <div class="absolute -bottom-20 -right-20 w-64 h-64 border-[1px] border-dashed border-secondary/30 rounded-full opacity-50 pointer-events-none"></div>
      
      <div class="flex items-center gap-3 mb-10 relative z-10">
        <div class="bg-surface p-2 rounded-xl border border-outline-variant/30 flex items-center justify-center shadow-sm">
          <span class="material-symbols-outlined text-secondary">school</span>
        </div>
        <h2 class="text-2xl font-bold text-on-background">Academic Core & Certifications</h2>
      </div>

      <div class="space-y-8 relative z-10 before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-[2px] before:bg-gradient-to-b before:from-secondary/40 before:to-transparent">
        {profileData.education.map((edu, index) => (
          <div class="relative flex items-center justify-between md:justify-normal md:even:flex-row-reverse group">
            <div class="flex items-center justify-center w-10 h-10 rounded-full border-4 border-surface bg-surface-container-lowest text-secondary shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-sm z-10">
              <span class="material-symbols-outlined text-[18px]">memory</span>
            </div>
            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 bg-surface-container-lowest border border-outline-variant/30 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
              <h3 class="font-bold text-on-background">{edu.degree}</h3>
              <div class="font-mono text-xs text-secondary mt-1">{edu.institution}</div>
              <div class="font-mono text-xs text-tertiary mt-2">GPA: <span class="font-bold text-primary">{edu.gpa}</span></div>
              <ul class="mt-4 space-y-2">
                {edu.highlights.map((highlight) => (
                  <li class="text-sm text-on-surface-variant flex items-start gap-2">
                    <span class="material-symbols-outlined text-[14px] text-primary mt-0.5">check_small</span>
                    {highlight}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 pt-8 border-t border-outline-variant/30 relative z-10">
        <h3 class="font-mono text-sm font-bold text-on-background uppercase tracking-widest mb-6">Professional Accreditations</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {profileData.certifications.map((cert) => (
            <div class="bg-surface-container-lowest p-4 rounded-xl border border-outline-variant/30 shadow-sm flex flex-col justify-center">
              <span class="font-semibold text-sm text-on-background mb-1">{cert.name}</span>
              <span class="text-xs font-mono text-secondary">{cert.issuer}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="md:col-span-4 bento-card p-8 md:p-10 flex flex-col relative overflow-hidden">
       <div class="absolute -top-10 -right-10 w-40 h-40 border-[1px] border-dashed border-primary/30 rounded-full opacity-50 pointer-events-none"></div>
       
       <div class="flex items-center gap-3 mb-8 relative z-10">
        <div class="bg-surface p-2 rounded-xl border border-outline-variant/30 flex items-center justify-center shadow-sm">
          <span class="material-symbols-outlined text-primary">diversity_1</span>
        </div>
        <h2 class="text-2xl font-bold text-on-background">Social Architecture</h2>
      </div>

      <div class="flex-grow flex flex-col gap-6 relative z-10">
        {activitiesData.map((activity) => (
          <div class="p-5 bg-surface-container-lowest rounded-2xl border border-outline-variant/30 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-bold text-sm text-on-background">{activity.title}</h3>
              <span class="text-[10px] uppercase tracking-wider font-mono px-2 py-1 bg-primary/10 text-primary border border-primary/20 rounded-lg shrink-0 ml-2">
                {activity.type}
              </span>
            </div>
            <p class="text-xs font-mono text-tertiary mb-3">@ {activity.organization}</p>
            <p class="text-sm text-on-surface-variant mb-4 leading-relaxed">{activity.description}</p>
            <div class="flex flex-wrap gap-2">
              {activity.highlights.map((h) => (
                <span class="text-[11px] font-mono text-secondary bg-secondary/5 px-2 py-1 rounded-md border border-secondary/10">{h}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
    
  </div>
</Layout>