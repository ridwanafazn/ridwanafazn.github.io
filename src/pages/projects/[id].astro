---
import Layout from '../../layouts/Layout.astro';
import Badge from '../../components/Badge.astro';
import projectsData from '../../data/projects.json';
import type { Project } from '../../types';

export function getStaticPaths() {
  return projectsData.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
const projectsLink = `${base.endsWith('/') ? base : base + '/'}projects`;
---

<Layout title={`${project.title} | Vault`}>
  <div class="pt-8 mb-8 relative z-10">
    <a href={projectsLink} class="inline-flex items-center gap-2 text-[11px] uppercase tracking-widest font-bold font-mono text-on-surface-variant hover:text-accent-indigo transition-colors">
      <span class="material-symbols-outlined text-[16px]">arrow_back</span>
      Return to Vault
    </a>
  </div>

  <article class="max-w-4xl mx-auto relative z-10">
    <header class="mb-12 text-center flex flex-col items-center">
      <span class="font-mono text-[10px] font-bold tracking-widest text-on-surface-variant uppercase mb-4 flex items-center gap-2">
        <span class="w-1.5 h-1.5 rounded-full bg-outline-strong"></span>
        Role // {project.role}
      </span>
      <h1 class="text-5xl md:text-6xl font-bold text-on-background mb-8 tracking-tight">
        {project.title}
      </h1>
      
      <div class="flex flex-wrap justify-center gap-2.5 mb-8">
        {project.techStack.map((tech) => (
          <Badge text={tech} />
        ))}
      </div>

      {project.links && project.links.length > 0 && (
        <div class="flex flex-wrap justify-center gap-4 pt-2">
          {project.links.map((link) => (
            <a 
              href={link.url} 
              target="_blank" 
              rel="noopener noreferrer" 
              class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full border border-outline-strong bg-surface/50 backdrop-blur-sm text-[11px] font-mono font-bold uppercase tracking-widest text-on-surface-variant hover:bg-on-background hover:text-surface hover:border-on-background transition-all duration-300 shadow-sm group"
            >
              <span class="material-symbols-outlined text-[16px] group-hover:text-surface transition-colors">{link.icon}</span>
              {link.label}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="bento-card p-8 md:p-12 relative overflow-hidden focus-visible:ring-2 focus-visible:ring-accent-indigo">
      
      <div class="absolute -top-32 -left-32 w-96 h-96 bg-accent-cyan/10 rounded-full blur-[100px] pointer-events-none z-0"></div>

      <div class="relative z-10">
        <section class="mb-12">
          <h2 class="text-2xl font-bold text-on-background mb-4 border-b border-outline/30 pb-4">System Overview</h2>
          <p class="text-[15px] text-on-surface-variant leading-relaxed font-medium">
            {project.description}
          </p>
        </section>

        {project.highlights && project.highlights.length > 0 && (
          <section class="mb-12">
            <h2 class="text-xl font-bold text-on-background mb-4 border-b border-outline/30 pb-4">Key Highlights & Engineering Feats</h2>
            <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
              {project.highlights.map((feat) => (
                <li class="flex items-start gap-3">
                  <span class="material-symbols-outlined text-accent-emerald mt-0.5 text-[18px]">check_circle</span>
                  <span class="text-[14px] text-on-surface-variant font-medium">{feat}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <section>
          <h2 class="text-xl font-bold text-on-background mb-6 border-b border-outline/30 pb-4">Architecture / Infrastructure Map</h2>
          
          <div class="w-full h-80 rounded-[2rem] border-2 border-dashed border-outline/40 bg-surface-container-lowest/30 backdrop-blur-sm flex flex-col items-center justify-center text-center p-6 group hover:border-accent-indigo/40 hover:bg-accent-indigo/5 transition-all duration-300">
            <span class="material-symbols-outlined text-4xl text-outline-strong mb-4 opacity-70 group-hover:opacity-100 group-hover:text-accent-indigo transition-all duration-300">
              architecture
            </span>
            <p class="font-mono text-[11px] font-bold uppercase tracking-widest text-on-surface-variant group-hover:text-accent-indigo transition-colors">
              [ Diagram Visualization Pending ]
            </p>
            <p class="font-mono text-[10px] text-on-surface-variant/70 mt-3">
              Insert SVG or Image of the system topology here.
            </p>
          </div>
        </section>
      </div>

    </div>
  </article>
</Layout>