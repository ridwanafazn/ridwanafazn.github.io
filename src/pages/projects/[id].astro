---
import Layout from '../../layouts/Layout.astro';
import Badge from '../../components/Badge.astro';
import projectsData from '../../data/projects.json';
import type { Project } from '../../types';

// Fungsi wajib Astro untuk meng-generate halaman statis berdasarkan array ID
export function getStaticPaths() {
  return projectsData.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${project.title} | Vault`}>
  <div class="pt-8 mb-8 relative z-10">
    <a href={`${base}projects`} class="inline-flex items-center gap-2 text-sm font-mono text-tertiary hover:text-primary transition-colors">
      <span class="material-symbols-outlined text-[16px]">arrow_back</span>
      Return to Vault
    </a>
  </div>

  <article class="max-w-4xl mx-auto relative z-10">
    <header class="mb-12 text-center flex flex-col items-center">
      <span class="font-mono text-xs font-bold tracking-widest text-secondary uppercase mb-4">
        Role // {project.role}
      </span>
      <h1 class="text-5xl md:text-6xl font-bold text-on-background mb-8 tracking-tight">
        {project.title}
      </h1>
      <div class="flex flex-wrap justify-center gap-3">
        {project.techStack.map((tech) => (
          <Badge text={tech} />
        ))}
      </div>
    </header>

    <div class="bento-card p-8 md:p-12">
      
      <section class="mb-12">
        <h2 class="text-2xl font-bold text-on-background mb-4 border-b border-outline-variant/30 pb-4">System Overview</h2>
        <p class="text-lg text-on-surface-variant leading-relaxed">
          {project.description}
        </p>
      </section>

      {project.highlights && project.highlights.length > 0 && (
        <section class="mb-12">
          <h2 class="text-xl font-bold text-on-background mb-4 border-b border-outline-variant/30 pb-4">Key Highlights & Engineering Feats</h2>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-6">
            {project.highlights.map((feat) => (
              <li class="flex items-start gap-3">
                <span class="material-symbols-outlined text-primary mt-0.5">check</span>
                <span class="text-on-surface-variant">{feat}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section>
        <h2 class="text-xl font-bold text-on-background mb-6 border-b border-outline-variant/30 pb-4">Architecture / Infrastructure Map</h2>
        
        <div class="w-full h-80 rounded-2xl border border-dashed border-outline-variant/60 bg-surface-container-lowest/50 flex flex-col items-center justify-center text-center p-6 group hover:border-primary/50 transition-colors duration-300">
          <span class="material-symbols-outlined text-4xl text-tertiary mb-4 opacity-50 group-hover:opacity-100 group-hover:text-primary transition-all duration-300">
            architecture
          </span>
          <p class="font-mono text-sm text-tertiary">
            [ Diagram Visualization Pending ]
          </p>
          <p class="font-mono text-xs text-tertiary/70 mt-2">
            Insert SVG or Image of the system topology here.
          </p>
        </div>
      </section>

    </div>
  </article>
</Layout>