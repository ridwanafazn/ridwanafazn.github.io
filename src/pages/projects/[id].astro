---
import Layout from '../../layouts/Layout.astro';
import Badge from '../../components/Badge.astro';
import projectsData from '../../data/projects.json';
import type { Project } from '../../types';

export function getStaticPaths() {
  return projectsData.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Layout title={`${project.title} - Architecture Detail`}>
  <article class="pt-10 max-w-3xl mx-auto">
    <!-- Header -->
    <header class="mb-10 text-center">
      <p class="font-mono text-teal-600 mb-3 tracking-wider text-sm uppercase">
        Role // {project.role}
      </p>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6">
        {project.title}
      </h1>
      <div class="flex flex-wrap justify-center gap-2 mb-6">
        {project.techStack.map((tech) => (
          <Badge text={tech} />
        ))}
      </div>
    </header>

    <!-- Content Breakdown -->
    <div class="bg-white rounded-2xl border border-slate-200 p-8 md:p-10 shadow-sm">
      <section class="mb-10">
        <h2 class="text-xl font-semibold text-slate-900 mb-4 border-b border-slate-100 pb-2">
          System Overview
        </h2>
        <p class="text-slate-600 leading-relaxed text-lg">
          {project.description}
        </p>
      </section>

      <section class="mb-10">
        <h2 class="text-xl font-semibold text-slate-900 mb-4 border-b border-slate-100 pb-2">
          Key Highlights & Engineering Feats
        </h2>
        <ul class="space-y-3">
          {project.highlights.map((highlight) => (
            <li class="flex items-start">
              <span class="text-teal-500 mr-3 mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
              </span>
              <span class="text-slate-700">{highlight}</span>
            </li>
          ))}
        </ul>
      </section>

      <!-- Architecture Visual Placeholder -->
      <section>
        <h2 class="text-xl font-semibold text-slate-900 mb-4 border-b border-slate-100 pb-2">
          Architecture / Infrastructure Map
        </h2>
        <div class="w-full bg-slate-50 border border-dashed border-slate-300 rounded-xl flex items-center justify-center p-12 text-slate-400 font-mono text-sm text-center">
          <div>
            <svg class="w-12 h-12 mx-auto mb-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <p>[ Diagram Visualization Pending ]</p>
            <p class="text-xs mt-1 opacity-70">Insert SVG or Image of the system topology here.</p>
          </div>
        </div>
      </section>
    </div>

    <!-- Back Button -->
    <div class="mt-12 text-center">
      <a href={`${base}projects`} class="inline-flex items-center gap-2 text-slate-500 hover:text-teal-600 transition-colors font-medium">
        <span>←</span> Back to Vault
      </a>
    </div>
  </article>
</Layout>