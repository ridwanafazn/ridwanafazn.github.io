---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Badge from '../components/Badge.astro';

import profileData from '../data/profile.json';
import projectsData from '../data/projects.json';
import skillsData from '../data/skills.json';

import type { Project } from '../types';

const topProjects = (projectsData as Project[]).filter((project) => project.isTopProject);
const base = import.meta.env.BASE_URL;
---

<Layout title="Architecture">
  <header class="mb-16 md:mb-24 mt-8 md:mt-16 max-w-4xl relative z-10">
    <p class="font-mono text-xs font-semibold text-secondary mb-4 uppercase tracking-widest flex items-center gap-3">
      <span class="w-8 h-[2px] bg-secondary inline-block"></span> 
      System Initialized // Profile: {profileData.name}
    </p>
    <h1 class="text-5xl md:text-6xl font-bold text-on-background mb-6 tracking-tight leading-tight">
      {profileData.role}.
    </h1>
    <h2 class="text-xl md:text-2xl text-on-surface-variant mb-6 font-medium">
      {profileData.tagline}
    </h2>
    <p class="text-base md:text-lg text-on-surface-variant leading-relaxed max-w-2xl mb-8">
      {profileData.bio}
    </p>
    <div class="flex flex-wrap gap-4">
      <a href="mailto:ridwanafazn@gmail.com" class="inline-flex items-center justify-center bg-primary-container text-on-primary-container font-mono text-sm font-bold px-6 py-3 rounded-full border border-primary-container/80 hover:opacity-90 active:scale-95 transition-all duration-300 shadow-sm">
        Initialize Contact
      </a>
      <a href={`${base}projects`} class="inline-flex items-center justify-center border border-outline-variant text-tertiary font-mono text-sm px-6 py-3 rounded-full hover:bg-surface-variant hover:text-on-background active:scale-95 transition-all duration-300">
        View Architecture Vault
      </a>
    </div>
  </header>

  <section class="mb-24 relative z-10">
    <div class="flex items-end justify-between border-b border-outline-variant/30 pb-4 mb-8">
      <h2 class="text-2xl font-bold text-on-background flex items-center gap-3">
        <span class="material-symbols-outlined text-tertiary">dashboard_customize</span> 
        Featured Masterpieces
      </h2>
      <a href={`${base}projects`} class="font-mono text-sm font-medium text-primary hover:opacity-80 flex items-center gap-1 transition-opacity">
        View Vault <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
      </a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
      {topProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <section class="mb-16 relative z-10">
     <div class="flex items-end justify-between border-b border-outline-variant/30 pb-4 mb-8">
        <h2 class="text-2xl font-bold text-on-background flex items-center gap-3">
          <span class="material-symbols-outlined text-secondary">memory</span> 
          Technical Arsenal
        </h2>
     </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
      {skillsData.map((skillGroup) => (
        <div class="bento-card p-8 flex flex-col min-h-[200px]">
          <h3 class="font-mono text-sm font-bold text-on-background uppercase tracking-widest mb-6 flex items-center gap-2">
             <span class="w-2 h-2 rounded-full bg-secondary/50"></span>
            {skillGroup.category}
          </h3>
          <div class="flex flex-wrap gap-2">
            {skillGroup.items.map((item) => (
              <Badge text={item} />
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>